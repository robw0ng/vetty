{
  "name": "vetty",
  "displayName": "Vetty",
  "description": "Vet code you didn't write — local code review for VS Code.",
  "version": "0.0.50",
  "publisher": "local",
  "license": "MIT",
  "author": "robw0ng",
  "repository": {
    "type": "git",
    "url": "https://github.com/robw0ng/vetty.git"
  },
  "bugs": {
    "url": "https://github.com/robw0ng/vetty/issues"
  },
  "homepage": "https://github.com/robw0ng/vetty#readme",
  "keywords": [
    "code review",
    "pull request",
    "PR",
    "diff",
    "branch diff",
    "review",
    "pre-commit",
    "self-review",
    "viewed",
    "changed files",
    "working tree",
    "local review",
    "git",
    "AI review"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node test/smoke.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "vetty.openAll",
        "title": "Open All Files Changed vs Branch",
        "category": "Vetty"
      },
      {
        "command": "vetty.openUnviewed",
        "title": "Open Unviewed Files Changed vs Branch",
        "category": "Vetty"
      },
      {
        "command": "vetty.openViewed",
        "title": "Open Viewed Files Changed vs Branch",
        "category": "Vetty"
      },
      {
        "command": "vetty.toggleViewed",
        "title": "Toggle Viewed",
        "category": "Vetty"
      },
      {
        "command": "vetty.markViewed",
        "title": "Mark Viewed",
        "category": "Vetty",
        "icon": "$(eye)"
      },
      {
        "command": "vetty.unmarkViewed",
        "title": "Mark Unviewed",
        "category": "Vetty",
        "icon": "$(eye-closed)"
      },
      {
        "command": "vetty.clearViewed",
        "title": "Clear Viewed Marks",
        "category": "Vetty"
      },
      {
        "command": "vetty.treePickBranch",
        "title": "Change Branch",
        "icon": "$(git-branch)"
      },
      {
        "command": "vetty.treeRefresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "vetty.fetch",
        "title": "Fetch & Refresh",
        "category": "Vetty",
        "icon": "$(cloud-download)"
      },
      {
        "command": "vetty.pickFolder",
        "title": "Pick Workspace Folder",
        "category": "Vetty",
        "icon": "$(root-folder)"
      },
      {
        "command": "vetty.treeOpenUnviewed",
        "title": "Open All Unviewed",
        "icon": "$(eye)"
      },
      {
        "command": "vetty.treeOpenFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "vetty.treeOpenDiff",
        "title": "Open as Diff",
        "icon": "$(git-compare)"
      },
      {
        "command": "vetty.treeView",
        "title": "View",
        "icon": "$(eye)"
      },
      {
        "command": "vetty.treeUnview",
        "title": "Unview",
        "icon": "$(eye-closed)"
      },
      {
        "command": "vetty.treeIgnore",
        "title": "Untrack File",
        "icon": "$(circle-slash)"
      },
      {
        "command": "vetty.treeUnignore",
        "title": "Track File",
        "icon": "$(check)"
      },
      {
        "command": "vetty.viewAsTree",
        "title": "View as Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "vetty.viewAsList",
        "title": "View as List",
        "icon": "$(list-flat)"
      },
      {
        "command": "vetty.hideWhitespace",
        "title": "Hide Whitespace-Only Changes",
        "category": "Vetty",
        "icon": "$(whitespace)"
      },
      {
        "command": "vetty.showWhitespace",
        "title": "Show Whitespace-Only Changes",
        "category": "Vetty",
        "icon": "$(whitespace)"
      },
      {
        "command": "vetty.diffSinceCommit",
        "title": "Range: Whole Branch (click for Uncommitted)",
        "category": "Vetty",
        "icon": "$(git-compare)"
      },
      {
        "command": "vetty.diffWholeBranch",
        "title": "Range: Uncommitted (click for Whole Branch)",
        "category": "Vetty",
        "icon": "$(git-commit)"
      },
      {
        "command": "vetty.sinceReviewOn",
        "title": "Compare: Base (click for Last Viewed)",
        "category": "Vetty",
        "icon": "$(eye-closed)"
      },
      {
        "command": "vetty.sinceReviewOff",
        "title": "Compare: Last Viewed (click for Base)",
        "category": "Vetty",
        "icon": "$(eye)"
      },
      {
        "command": "vetty.reviewPr",
        "title": "Review Pull Request",
        "category": "Vetty",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "vetty.finishReview",
        "title": "Finish Review",
        "category": "Vetty",
        "icon": "$(sign-out)"
      },
      {
        "command": "vetty.submitReview",
        "title": "Submit Review to PR",
        "category": "Vetty",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vetty.togglePrMode",
        "title": "Toggle PR Mode",
        "category": "Vetty"
      },
      {
        "command": "vetty.stageViewed",
        "title": "Stage Viewed Files",
        "category": "Vetty",
        "icon": "$(add)"
      },
      {
        "command": "vetty.stageFile",
        "title": "Stage",
        "icon": "$(add)"
      },
      {
        "command": "vetty.addToGroup",
        "title": "Add to Group",
        "category": "Vetty"
      },
      {
        "command": "vetty.removeFromGroup",
        "title": "Remove from Group",
        "category": "Vetty"
      },
      {
        "command": "vetty.stageGroup",
        "title": "Stage Group",
        "category": "Vetty",
        "icon": "$(layers)"
      },
      {
        "command": "vetty.openGroup",
        "title": "Open Group",
        "category": "Vetty"
      },
      {
        "command": "vetty.markGroupViewed",
        "title": "Mark Group Viewed",
        "category": "Vetty"
      },
      {
        "command": "vetty.collapseAll",
        "title": "Collapse All",
        "category": "Vetty",
        "icon": "$(collapse-all)"
      },
      {
        "command": "vetty.expandAll",
        "title": "Expand All",
        "category": "Vetty",
        "icon": "$(expand-all)"
      },
      {
        "command": "vetty.ungroup",
        "title": "Ungroup…",
        "category": "Vetty",
        "icon": "$(close)"
      },
      {
        "command": "vetty.clearGroups",
        "title": "Ungroup All",
        "category": "Vetty"
      },
      {
        "command": "vetty.copyPaths",
        "title": "Copy Path(s)"
      },
      {
        "command": "vetty.copyTodos",
        "title": "Copy TODO(s)"
      },
      {
        "command": "vetty.showMore",
        "title": "Show More Files"
      },
      {
        "command": "vetty.nextUnviewed",
        "title": "Open Next Unviewed File",
        "category": "Vetty"
      },
      {
        "command": "vetty.prevUnviewed",
        "title": "Open Previous Unviewed File",
        "category": "Vetty"
      },
      {
        "command": "vetty.viewCurrent",
        "title": "Toggle Viewed (active file)",
        "category": "Vetty"
      },
      {
        "command": "vetty.treeOpenGroup",
        "title": "Open All in Group",
        "icon": "$(go-to-file)"
      },
      {
        "command": "vetty.treeMarkAllViewed",
        "title": "View All",
        "icon": "$(eye-closed)"
      },
      {
        "command": "vetty.treeMarkAllUnviewed",
        "title": "Unview All",
        "icon": "$(eye)"
      },
      {
        "command": "vetty.pullPrComments",
        "title": "Pull PR Comments",
        "category": "Vetty",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vetty.exportComments",
        "title": "Export Comments to Clipboard",
        "category": "Vetty",
        "icon": "$(copy)"
      },
      {
        "command": "vetty.clearComments",
        "title": "Clear All Comments",
        "category": "Vetty",
        "icon": "$(clear-all)"
      },
      {
        "command": "vetty.createComment",
        "title": "Add Comment"
      },
      {
        "command": "vetty.deleteComment",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "vetty.copyComment",
        "title": "Copy Comment",
        "icon": "$(copy)"
      },
      {
        "command": "vetty.editComment",
        "title": "Edit Comment",
        "icon": "$(edit)"
      },
      {
        "command": "vetty.saveComment",
        "title": "Save"
      },
      {
        "command": "vetty.cancelEditComment",
        "title": "Cancel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vetty",
          "title": "Vetty",
          "icon": "$(git-compare)"
        }
      ]
    },
    "views": {
      "vetty": [
        {
          "type": "webview",
          "id": "vettySearch",
          "name": "Search"
        },
        {
          "id": "vettyView",
          "name": "Review"
        },
        {
          "id": "vettyTodos",
          "name": "Todos"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vettyView",
        "when": "!vetty.hasBase",
        "contents": "Review the files your branch changed.\n\nVetty diffs against the inferred parent branch and tracks what you've reviewed.\n[Pick a base branch](command:vetty.treePickBranch)\n\nReviewing a teammate's PR? Enable PR mode in settings, then [Review a Pull Request](command:vetty.reviewPr)."
      },
      {
        "view": "vettyView",
        "when": "vetty.hasBase",
        "contents": "No changes vs the base branch.\n\nMake some edits, or [change the base branch](command:vetty.treePickBranch)."
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vetty.markViewed",
          "group": "navigation",
          "when": "!vetty.activeViewed"
        },
        {
          "command": "vetty.unmarkViewed",
          "group": "navigation",
          "when": "vetty.activeViewed"
        }
      ],
      "view/title": [
        {
          "command": "vetty.reviewPr",
          "when": "view == vettyView && vetty.prMode && !vetty.reviewing",
          "group": "navigation@0"
        },
        {
          "command": "vetty.submitReview",
          "when": "view == vettyView && vetty.reviewing",
          "group": "navigation@0"
        },
        {
          "command": "vetty.finishReview",
          "when": "view == vettyView && vetty.reviewing",
          "group": "navigation@1"
        },
        {
          "command": "vetty.treePickBranch",
          "when": "view == vettyView",
          "group": "navigation@2"
        },
        {
          "command": "vetty.treeRefresh",
          "when": "view == vettyView",
          "group": "navigation@3"
        },
        {
          "command": "vetty.diffSinceCommit",
          "when": "view == vettyView && vetty.diffRange != commit",
          "group": "navigation@4"
        },
        {
          "command": "vetty.diffWholeBranch",
          "when": "view == vettyView && vetty.diffRange == commit",
          "group": "navigation@4"
        },
        {
          "command": "vetty.sinceReviewOn",
          "when": "view == vettyView && !vetty.sinceReview",
          "group": "navigation@5"
        },
        {
          "command": "vetty.sinceReviewOff",
          "when": "view == vettyView && vetty.sinceReview",
          "group": "navigation@5"
        },
        {
          "command": "vetty.viewAsTree",
          "when": "view == vettyView && !vetty.nested",
          "group": "2_view@1"
        },
        {
          "command": "vetty.viewAsList",
          "when": "view == vettyView && vetty.nested",
          "group": "2_view@1"
        },
        {
          "command": "vetty.expandAll",
          "when": "view == vettyView && vetty.nested",
          "group": "2_view@2"
        },
        {
          "command": "vetty.collapseAll",
          "when": "view == vettyView && vetty.nested",
          "group": "2_view@3"
        },
        {
          "command": "vetty.hideWhitespace",
          "when": "view == vettyView && !vetty.hideWhitespace",
          "group": "2_view@4"
        },
        {
          "command": "vetty.showWhitespace",
          "when": "view == vettyView && vetty.hideWhitespace",
          "group": "2_view@4"
        },
        {
          "command": "vetty.fetch",
          "when": "view == vettyView",
          "group": "3_git@1"
        },
        {
          "command": "vetty.pickFolder",
          "when": "view == vettyView && workspaceFolderCount > 1",
          "group": "3_git@2"
        },
        {
          "command": "vetty.exportComments",
          "when": "view == vettyView",
          "group": "1_comments@1"
        },
        {
          "command": "vetty.pullPrComments",
          "when": "view == vettyView && vetty.prMode",
          "group": "1_comments@2"
        },
        {
          "command": "vetty.clearComments",
          "when": "view == vettyView",
          "group": "1_comments@3"
        }
      ],
      "view/item/context": [
        {
          "command": "vetty.treeOpenGroup",
          "when": "view == vettyView && viewItem =~ /^group-/",
          "group": "inline@0"
        },
        {
          "command": "vetty.treeMarkAllViewed",
          "when": "view == vettyView && viewItem == group-unviewed",
          "group": "inline@1"
        },
        {
          "command": "vetty.treeMarkAllUnviewed",
          "when": "view == vettyView && viewItem == group-viewed",
          "group": "inline@1"
        },
        {
          "command": "vetty.stageViewed",
          "when": "view == vettyView && viewItem == group-viewed",
          "group": "inline@2"
        },
        {
          "command": "vetty.treeIgnore",
          "when": "view == vettyView && viewItem =~ /^file-(viewed|unviewed)$/",
          "group": "inline@1"
        },
        {
          "command": "vetty.treeUnignore",
          "when": "view == vettyView && viewItem == file-ignored",
          "group": "inline@1"
        },
        {
          "command": "vetty.treeOpenFile",
          "when": "view == vettyView && viewItem =~ /^file-/",
          "group": "inline@2"
        },
        {
          "command": "vetty.treeView",
          "when": "view == vettyView && viewItem == file-unviewed",
          "group": "inline@3"
        },
        {
          "command": "vetty.treeUnview",
          "when": "view == vettyView && viewItem == file-viewed",
          "group": "inline@3"
        },
        {
          "command": "vetty.stageFile",
          "when": "view == vettyView && viewItem == file-viewed",
          "group": "inline@4"
        },
        {
          "command": "vetty.stageFile",
          "when": "view == vettyView && viewItem =~ /^file-(viewed|unviewed)$/",
          "group": "navigation@5"
        },
        {
          "command": "vetty.treeOpenDiff",
          "when": "view == vettyView && viewItem =~ /^file-/",
          "group": "navigation@1"
        },
        {
          "command": "vetty.treeOpenFile",
          "when": "view == vettyView && viewItem =~ /^file-/",
          "group": "navigation@2"
        },
        {
          "command": "vetty.treeView",
          "when": "view == vettyView && viewItem == file-unviewed",
          "group": "navigation@0"
        },
        {
          "command": "vetty.treeUnview",
          "when": "view == vettyView && viewItem == file-viewed",
          "group": "navigation@0"
        },
        {
          "command": "vetty.treeIgnore",
          "when": "view == vettyView && viewItem =~ /^file-(viewed|unviewed)$/",
          "group": "navigation@4"
        },
        {
          "command": "vetty.treeUnignore",
          "when": "view == vettyView && viewItem == file-ignored",
          "group": "navigation@4"
        },
        {
          "command": "vetty.addToGroup",
          "when": "view == vettyView && viewItem =~ /^file-/",
          "group": "navigation@6"
        },
        {
          "command": "vetty.removeFromGroup",
          "when": "view == vettyView && viewItem =~ /^file-/",
          "group": "navigation@7"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "vetty.createComment",
          "group": "inline",
          "when": "commentController == vetty.comments"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "vetty.deleteComment",
          "group": "inline",
          "when": "commentController == vetty.comments && commentThread == hasComment"
        }
      ],
      "comments/comment/title": [
        {
          "command": "vetty.editComment",
          "group": "inline@1",
          "when": "commentController == vetty.comments && comment == editable"
        },
        {
          "command": "vetty.copyComment",
          "group": "inline@2",
          "when": "commentController == vetty.comments"
        }
      ],
      "comments/comment/context": [
        {
          "command": "vetty.saveComment",
          "group": "inline@1",
          "when": "commentController == vetty.comments && comment == editable"
        },
        {
          "command": "vetty.cancelEditComment",
          "group": "inline@2",
          "when": "commentController == vetty.comments && comment == editable"
        }
      ],
      "commandPalette": [
        {
          "command": "vetty.markViewed",
          "when": "false"
        },
        {
          "command": "vetty.unmarkViewed",
          "when": "false"
        },
        {
          "command": "vetty.treePickBranch",
          "when": "false"
        },
        {
          "command": "vetty.treeRefresh",
          "when": "false"
        },
        {
          "command": "vetty.treeOpenUnviewed",
          "when": "false"
        },
        {
          "command": "vetty.treeOpenFile",
          "when": "false"
        },
        {
          "command": "vetty.treeOpenDiff",
          "when": "false"
        },
        {
          "command": "vetty.viewAsTree",
          "when": "false"
        },
        {
          "command": "vetty.viewAsList",
          "when": "false"
        },
        {
          "command": "vetty.treeView",
          "when": "false"
        },
        {
          "command": "vetty.treeUnview",
          "when": "false"
        },
        {
          "command": "vetty.treeIgnore",
          "when": "false"
        },
        {
          "command": "vetty.treeUnignore",
          "when": "false"
        },
        {
          "command": "vetty.addToGroup",
          "when": "false"
        },
        {
          "command": "vetty.removeFromGroup",
          "when": "false"
        },
        {
          "command": "vetty.treeMarkAllViewed",
          "when": "false"
        },
        {
          "command": "vetty.treeMarkAllUnviewed",
          "when": "false"
        },
        {
          "command": "vetty.createComment",
          "when": "false"
        },
        {
          "command": "vetty.deleteComment",
          "when": "false"
        },
        {
          "command": "vetty.copyComment",
          "when": "false"
        },
        {
          "command": "vetty.editComment",
          "when": "false"
        },
        {
          "command": "vetty.saveComment",
          "when": "false"
        },
        {
          "command": "vetty.cancelEditComment",
          "when": "false"
        },
        {
          "command": "vetty.copyPaths",
          "when": "false"
        },
        {
          "command": "vetty.copyTodos",
          "when": "false"
        },
        {
          "command": "vetty.showMore",
          "when": "false"
        },
        {
          "command": "vetty.stageFile",
          "when": "false"
        },
        {
          "command": "vetty.openTodo",
          "when": "false"
        },
        {
          "command": "vetty.openMatch",
          "when": "false"
        },
        {
          "command": "vetty.reviewPr",
          "when": "vetty.prMode"
        },
        {
          "command": "vetty.finishReview",
          "when": "vetty.reviewing"
        },
        {
          "command": "vetty.submitReview",
          "when": "vetty.reviewing"
        },
        {
          "command": "vetty.nextUnviewed",
          "when": "false"
        },
        {
          "command": "vetty.prevUnviewed",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vetty.copyPaths",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == vettyView"
      },
      {
        "command": "vetty.copyTodos",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == vettyTodos"
      },
      {
        "command": "vetty.nextUnviewed",
        "key": "j",
        "when": "focusedView == vettyView"
      },
      {
        "command": "vetty.prevUnviewed",
        "key": "k",
        "when": "focusedView == vettyView"
      },
      {
        "command": "vetty.viewCurrent",
        "key": "v",
        "when": "focusedView == vettyView"
      }
    ],
    "configuration": {
      "title": "Vetty",
      "properties": {
        "vetty.pullRequests.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Experimental: enable GitHub pull request review (checkout PRs, see/submit reviews). Off by default. Requires the GitHub CLI `gh`."
        }
      }
    }
  }
}
